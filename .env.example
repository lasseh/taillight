# Taillight environment configuration
#
# Copy this file to .env and adjust values for your environment.
# Docker Compose reads .env automatically from the project root.
#
# This file holds per-deployment settings (passwords, ports, feature toggles).
# Application tuning (retention, notifications, SMTP, etc.) lives in api/config.yml.

# --- PostgreSQL ---
# Used by the postgres container AND by the API + rsyslog to connect.
POSTGRES_PASSWORD=taillight

# --- Host ports ---
# Control how you reach services from the host machine.
# Container-to-container communication always uses internal ports.
POSTGRES_HOST_PORT=5432
API_HOST_PORT=8080
FRONTEND_HOST_PORT=3000

# Host port for syslog ingestion (UDP + TCP).
# Default 1514 for development; set to 514 in production.
RSYSLOG_HOST_PORT=1514

# --- API settings ---
# Log level: debug, info, warn, error.
LOG_LEVEL=info

# Enable authentication (login, sessions, API keys).
# Set to false for deployments behind a firewall where all users should have access.
AUTH_ENABLED=false

# --- Frontend ---
# Leave empty for same-origin proxy mode (nginx routes /api to the backend).
# Set to http://localhost:8080 for local dev without a reverse proxy.
API_URL=
