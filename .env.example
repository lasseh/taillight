# Taillight environment configuration
#
# Copy this file to .env and adjust values for your environment.
# Docker Compose reads .env automatically from the project root.
#
# IMPORTANT: Host ports control how you reach services from your machine.
# Container-to-container communication always uses the internal port
# (e.g. postgres listens on 5432 inside Docker regardless of the host port).

# --- PostgreSQL ---
POSTGRES_PASSWORD=taillight

# Host port for PostgreSQL. Change this if port 5432 is already in use
# on the host (e.g. an existing PostgreSQL instance).
# The API and rsyslog containers always connect to postgres:5432 internally.
POSTGRES_HOST_PORT=5432

# --- API ---
# Host port for the taillight API.
API_HOST_PORT=8080

# --- rsyslog ---
# Host port for syslog ingestion (UDP + TCP).
# Default is 1514 for development to avoid conflicts.
# Set to 514 in production so devices can use the standard syslog port.
RSYSLOG_HOST_PORT=1514

# --- Frontend ---
# Host port for the web UI.
FRONTEND_HOST_PORT=3000

# --- Frontend API URL ---
# Leave empty for same-origin proxy mode (nginx routes /api to the backend).
# Set to http://localhost:8080 for local dev without a reverse proxy.
API_URL=

# --- rsyslog PostgreSQL connection ---
# These configure the ompgsql connection inside the rsyslog container.
# Defaults match docker-compose.yml and work with standard bridge networking.
# Only change these if you use host networking or an external database.
PGSQL_SERVER=postgres
PGSQL_PORT=5432
PGSQL_DB=taillight
PGSQL_USER=taillight
PGSQL_PASSWORD=taillight
