# Taillight — production nginx reverse proxy
#
# Place behind your TLS terminator or configure ssl_certificate below.
# Adjust server_name and proxy_pass addresses to match your deployment.
#
# Features:
#   - SSE streaming support (proxy_buffering off, long read timeout)
#   - Rate limiting on auth and API endpoints
#   - Security headers (X-Frame-Options, X-Content-Type-Options, Referrer-Policy)
#   - Gzip compression for JSON and static assets
#   - HTTP → HTTPS redirect

# Rate limit zones — keyed by client IP.
limit_req_zone $binary_remote_addr zone=login:10m rate=10r/m;
limit_req_zone $binary_remote_addr zone=api:10m   rate=30r/s;

server {
    listen 443 ssl http2;
    server_name taillight.example.com;

    ssl_certificate     /etc/ssl/certs/taillight.pem;
    ssl_certificate_key /etc/ssl/private/taillight.key;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    # Security headers
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Common proxy headers
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # Gzip
    gzip on;
    gzip_types application/json text/plain text/css application/javascript;
    gzip_min_length 256;

    # ── Auth: login endpoint — strict rate limit ──────────────────────
    location = /api/v1/auth/login {
        limit_req zone=login burst=5 delay=3;
        limit_req_status 429;

        proxy_pass http://127.0.0.1:8080;
    }

    # ── SSE streams — long-lived, no buffering ────────────────────────
    location ~ ^/api/v1/(syslog|applog)/stream$ {
        proxy_pass http://127.0.0.1:8080;

        proxy_http_version 1.1;
        proxy_set_header Connection '';
        proxy_buffering off;
        proxy_cache off;
        chunked_transfer_encoding off;

        # Keep the connection alive for up to 24 h.
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
    }

    # ── General API — moderate rate limit ─────────────────────────────
    location /api/ {
        limit_req zone=api burst=50 delay=20;
        limit_req_status 429;

        proxy_pass http://127.0.0.1:8080;
    }

    # ── Health check endpoint (no rate limit) ─────────────────────────
    location = /health {
        proxy_pass http://127.0.0.1:8080;
    }

    # ── Frontend (proxied to frontend container) ─────────────────────
    location / {
        proxy_pass http://127.0.0.1:3000;
    }
}

# Redirect HTTP → HTTPS
server {
    listen 80;
    server_name taillight.example.com;
    return 301 https://$host$request_uri;
}
