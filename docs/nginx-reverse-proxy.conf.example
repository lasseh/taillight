# Taillight — production nginx reverse proxy
#
# Adjust server_name, ssl paths, and proxy_pass addresses for your deployment.
#
# Features:
#   - SSE streaming (proxy_buffering off, 24h read timeout)
#   - Rate limiting on auth and API endpoints
#   - TLS 1.2/1.3 with session resumption and OCSP stapling
#   - HSTS and security headers
#   - Gzip compression for JSON and static assets
#   - HTTP → HTTPS redirect

# ── Upstreams — change ports here, not in every location block ────
upstream taillight_api {
    server 127.0.0.1:8080;
    keepalive 32;
}

upstream taillight_frontend {
    server 127.0.0.1:3000;
    keepalive 4;
}

# Rate limit zones — keyed by client IP.
limit_req_zone $binary_remote_addr zone=login:10m rate=10r/m;
limit_req_zone $binary_remote_addr zone=api:10m   rate=30r/s;

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name taillight.example.com;

    # ── TLS ──────────────────────────────────────────────────────────
    # Remove this block if your nginx already sets TLS globally
    # (e.g. conf.d/tls-intermediate.conf) to avoid shared zone conflicts.
    ssl_certificate     /etc/ssl/certs/taillight.pem;
    ssl_certificate_key /etc/ssl/private/taillight.key;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    ssl_stapling on;
    ssl_stapling_verify on;
    resolver 1.1.1.1 8.8.8.8 valid=300s;
    resolver_timeout 5s;

    # ── Security headers ─────────────────────────────────────────────
    # If using lasseh/nginx-conf, replace with: include snippets/security-headers.conf;
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # ── Proxy headers (inherited by all location blocks) ─────────────
    # If using lasseh/nginx-conf, replace with: include snippets/proxy-headers.conf;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host  $host;
    proxy_set_header X-Request-ID      $request_id;

    # TCP keepalive to detect dead backend connections
    proxy_socket_keepalive on;

    # ── Gzip ─────────────────────────────────────────────────────────
    # If using lasseh/nginx-conf, replace with: include snippets/gzip.conf;
    gzip on;
    gzip_static on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_min_length 1024;
    gzip_types
        application/javascript
        application/json
        application/manifest+json
        text/css
        text/javascript
        text/plain
        image/svg+xml;

    # ── Auth: login endpoint — strict rate limit ─────────────────────
    location = /api/v1/auth/login {
        limit_req zone=login burst=5 delay=3;
        limit_req_status 429;

        proxy_pass http://taillight_api;
    }

    # ── SSE streams — long-lived, no buffering ───────────────────────
    # Only 4 directives beyond standard proxy: buffering off, long read
    # timeout, HTTP/1.1, and empty Connection header for keepalive.
    # Backend sends heartbeat comments every 30s to prevent read timeout.
    location ~ ^/api/v1/(syslog|applog)/stream$ {
        proxy_pass http://taillight_api;

        proxy_buffering            off;
        proxy_read_timeout         24h;
        proxy_http_version         1.1;
        proxy_set_header Connection "";
    }

    # ── General API — moderate rate limit ────────────────────────────
    location /api/ {
        limit_req zone=api burst=50 delay=20;
        limit_req_status 429;

        proxy_pass http://taillight_api;
    }

    # ── Health check endpoint (no rate limit) ────────────────────────
    location = /health {
        proxy_pass http://taillight_api;
    }

    # ── Frontend — hashed static assets (1 year cache) ───────────────
    location ~* ^/assets/.*\.(js|css|woff2?|png|jpg|svg|ico)$ {
        proxy_pass http://taillight_frontend;
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # ── Frontend — SPA shell (revalidate every request) ───────────────
    location / {
        proxy_pass http://taillight_frontend;
        add_header Cache-Control "no-cache";
    }
}

# Redirect HTTP → HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name taillight.example.com;
    return 301 https://$host$request_uri;
}
