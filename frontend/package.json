{
  "name": "taillight-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b tsconfig.app.json tsconfig.node.json && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --build",
    "test": "NODE_OPTIONS=--disable-warning=DEP0205 vitest run",
    "test:watch": "NODE_OPTIONS=--disable-warning=DEP0205 vitest",
    "coverage": "NODE_OPTIONS=--disable-warning=DEP0205 vitest run --coverage",
    "lint:js": "eslint .",
    "lint:js:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@unovis/ts": "^1.6.7",
    "@unovis/vue": "^1.6.7",
    "@vueuse/core": "^14.3.0",
    "dompurify": "^3.4.11",
    "focus-trap": "^8.2.2",
    "marked": "^18.0.6",
    "pinia": "^3.0.4",
    "prismjs": "^1.30.0",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^25.7.0",
    "@types/prismjs": "^1.26.5",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "3.8.3",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0",
    "typescript-eslint": "8.64.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue-eslint-parser": "10.4.1",
    "vue-tsc": "^3.2.8"
  },
  "overrides": {
    "glob": "^13.0.0",
    "js-cookie": ">=3.0.6",
    "brace-expansion@5.0.5": "5.0.6"
  }
}
