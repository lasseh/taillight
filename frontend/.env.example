# Frontend local development settings (npm run dev only).
#
# These variables configure Vite's dev server proxy. They have NO effect
# in Docker — the Docker frontend uses API_URL from the root .env instead.
#
# Copy to .env when running the frontend outside Docker:
#   cp .env.example .env
#   npm run dev

# Backend API target for Vite's dev proxy (/api -> this URL).
# Default: http://localhost:8080
VITE_API_TARGET=http://localhost:8080
